APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — Mailpit (local dev / testing)
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null

# Mail — Brevo (production) — replace values below and change MAIL_MAILER to smtp:
# MAIL_HOST=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_USERNAME=your_brevo_login@email.com
# MAIL_PASSWORD=your_brevo_smtp_key
# MAIL_ENCRYPTION=tls

MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

GAINT_SMS_SENDER_ID=
GAINT_SMS_USERNAME=
GAINT_SMS_PASSWORD=
GAINT_SMS_API_TOKEN=

MNOTIFY_SENDER_ID=
MNOTIFY_API_KEY=

# ── Payment Gateway ────────────────────────────────────────────────────────────
# Which gateway to use: 'transflow' (default) or 'moolre'
PAYMENT_GATEWAY=transflow

# Moolre (direct MoMo push — no redirect)
MOOLRE_BASE_URL=https://api.moolre.com/open/transact
MOOLRE_API_USER=your_moolre_username
MOOLRE_API_KEY=your_moolre_api_key
MOOLRE_API_PUBKEY=your_public_key
MOOLRE_MERCHANT_ID=your_merchant_number
MOOLRE_WEBHOOK_SECRET=your_webhook_secret

# Transflow (hosted checkout — MoMo + card)
# Base URL is auto-selected from APP_ENV: UAT on local/staging, live on production.
# Set TRANSFLOW_BASE_URL only if you need to override the auto-selection.
# TRANSFLOW_BASE_URL=https://apisuat.itcsrvc.com/checkout
TRANSFLOW_API_KEY=your_transflow_api_key
TRANSFLOW_ID=your_transflow_id
TRANSFLOW_MERCHANT_PRODUCT_ID=your_merchant_product_id


GOOGLE_ANALYTICS_ID=G-XXXXXXXXXXX